// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CARETAKER
  CAREGIVER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id                 String      @id @default(cuid()) //CUID (Collision-Resistant Unique Identifier)
  name               String
  email              String      @unique
  password           String
  role               Role        @default(CARETAKER)
  createdAt          DateTime    @default(now())
  caregiverProfile   Caregiver?  @relation("CaregiverProfile") // 1️⃣ If user is a caregiver
  approvedCaregivers Caregiver[] @relation("ApprovedBy") // 2️⃣ If user is an admin approving caregivers
  caretakerProfile   Caretaker?  @relation("caretakerProfile")
}

model Caregiver {
  id               String              @id @default(uuid())
  userId           String              @unique
  firstName        String
  middleName       String?
  lastName         String
  nameWithInitials String?
  phone            String
  nic              String              @unique
  gender           Gender
  dateOfBirth      DateTime
  // address          String
  secondaryPhone   String?
  addressLine1     String
  addressLine2     String?
  city             String
  postalCode       String?
  district         District
  experienceYears  Int
  bio              String?
  hourlyRate       Float?
  status           CaregiverStatus     @default(DRAFT)
  adminNote        String? // Admin note
  approvedById     String? //Admin ID
  documents        CaregiverDocument[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // =============================
  // PROFESSIONAL DETAILS
  // =============================
  qualifications  String? // NEW - NVQ, Diploma, Nursing etc
  certifications  String? // NEW - First Aid, CPR, etc
  specialization  String? // NEW - Dementia care, Bedridden care
  languagesSpoken String? // NEW - Sinhala, Tamil, English

  // =============================
  // SKILL FLAGS (for matching)
  // =============================
  canHandleDementia       Boolean @default(false) // NEW
  canHandleBedridden      Boolean @default(false) // NEW
  canHandleWheelchair     Boolean @default(false) // NEW
  canProvidePhysiotherapy Boolean @default(false) // NEW
  canAdministerMedication Boolean @default(false) // NEW
  canHandleEmergency      Boolean @default(false) // NEW

  // =============================
  // AVAILABILITY
  // =============================
  isAvailable          Boolean   @default(true) // NEW
  availableFrom        DateTime? // NEW
  availableTo          DateTime? // NEW
  availableForNight    Boolean   @default(false) // NEW
  availableForFullTime Boolean   @default(false) // NEW

  // =============================
  // VERIFICATION & SAFETY
  // =============================
  isIdentityVerified  Boolean   @default(false) // NEW
  isBackgroundChecked Boolean   @default(false) // NEW
  backgroundCheckDate DateTime? // NEW
  // emergencyContactName  String? // NEW
  // emergencyContactPhone String? // NEW

  // =============================
  // RATING & PERFORMANCE
  // =============================
  averageRating      Float? // NEW - calculated from reviews
  totalReviews       Int    @default(0) // NEW
  totalCompletedJobs Int    @default(0) // NEW

  // =============================
  // SYSTEM
  // =============================
  isActive Boolean @default(true) // NEW - soft delete control

  user                      User                       @relation("CaregiverProfile", fields: [userId], references: [id])
  approvedBy                User?                      @relation("ApprovedBy", fields: [approvedById], references: [id])
  caregiverProfileVersions  CaregiverProfileVersion[]
  caregiverDocumentVersions CaregiverDocumentVersion[]
  bookings                  Booking[]
}

model CaregiverDocument {
  id          String       @id @default(uuid())
  caregiverId String       @unique
  type        DocumentType
  fileUrl     String
  verified    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  caregiver   Caregiver    @relation(fields: [caregiverId], references: [id])
}

enum CaregiverStatus {
  DRAFT // profile not submitted yet
  SUBMITTED // waiting admin review
  UNDER_REVIEW // admin is looking in to it
  APPROVED // admin approved
  REJECTED // rejected permanently
  CHANGES_REQUIRED // admin requested changes
}

enum DocumentType {
  NIC
  CERTIFICATE
  POLICE_REPORT
}

enum District {
  // Western Province
  COLOMBO
  GAMPAHA
  KALUTARA

  // Central Province
  KANDY
  MATALE
  NUWARA_ELIYA

  // Southern Province
  GALLE
  MATARA
  HAMBANTOTA

  // Northern Province
  JAFFNA
  KILINOCHCHI
  MANNAR
  MULLAITIVU
  VAVUNIYA

  // Eastern Province
  TRINCOMALEE
  BATTICALOA
  AMPARA

  // North Western Province
  KURUNEGALA
  PUTTALAM

  // North Central Province
  ANURADHAPURA
  POLONNARUWA

  // Uva Province
  BADULLA
  MONARAGALA

  // Sabaragamuwa Province
  RATNAPURA
  KEGALLE
}

model Caretaker {
  id     String @id @default(uuid())
  userId String @unique

  // Personal Details
  firstName        String
  middleName       String?
  lastName         String
  nameWithInitials String?
  nic              String?
  dateOfBirth      DateTime?
  gender           Gender

  // Contact Details
  phone          String
  secondaryPhone String?
  addressLine1   String
  addressLine2   String?
  city           String
  district       District
  postalCode     String?

  // Relationship & Responsibility
  relationshipToElder   RelationshipType
  relationshipTypeOther String?
  isPrimaryContact      Boolean          @default(true)

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // System Fields
  isVerified Boolean @default(false)
  notes      String?

  // Relations
  elders Elder[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  //  user       User  @relation("CaregiverProfile", fields: [userId], references: [id])
  user      User      @relation("caretakerProfile", fields: [userId], references: [id])
  bookings  Booking[]
}

enum RelationshipType {
  SON
  DAUGHTER
  SPOUSE
  RELATIVE
  LEGAL_GUARDIAN
  OTHER
}

model Elder {
  id          String @id @default(uuid())
  caretakerId String @unique

  // -----------------------
  // Basic Identity
  // -----------------------
  firstName   String
  middleName  String?
  lastName    String
  gender      Gender
  dateOfBirth DateTime
  nic         String?
  bloodGroup  BloodGroup?

  // -----------------------
  // Physical Information
  // -----------------------
  heightCm      Float?
  weightKg      Float?
  mobilityLevel MobilityLevel
  visionIssues  Boolean       @default(false)
  hearingIssues Boolean       @default(false)

  // -----------------------
  // Medical Profile
  // -----------------------
  chronicDiseases    String? // Diabetes, Hypertension etc
  allergies          String?
  currentMedications String?
  pastSurgeries      String?
  medicalNotes       String?

  // -----------------------
  // Cognitive & Mental
  // -----------------------
  hasDementia    Boolean @default(false)
  hasAlzheimer   Boolean @default(false)
  hasDepression  Boolean @default(false)
  cognitiveNotes String?

  // -----------------------
  // Care Requirements
  // -----------------------
  requiresFullTimeCare  Boolean @default(false)
  requiresNightCare     Boolean @default(false)
  requiresPhysiotherapy Boolean @default(false)
  requiresSpecialDiet   Boolean @default(false)
  specialNeeds          String?

  // -----------------------
  // Risk & Monitoring
  // -----------------------
  fallRiskLevel      RiskLevel @default(LOW)
  requiresMonitoring Boolean   @default(false)

  // -----------------------
  // Emergency Info
  // -----------------------
  emergencyDoctorName  String?
  emergencyDoctorPhone String?
  preferredHospital    String?

  // -----------------------
  // System
  // -----------------------
  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caretaker Caretaker @relation(fields: [caretakerId], references: [id])
  bookings  Booking[]
}

enum MobilityLevel {
  INDEPENDENT
  NEEDS_ASSISTANCE
  WHEELCHAIR
  BEDRIDDEN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

model CaregiverProfileVersion {
  id            String          @id @default(uuid())
  caregiverId   String
  versionNumber Int
  data          Json // Stores the submitted profile snapshot
  status        CaregiverStatus @default(DRAFT) // PENDING, APPROVED, REJECTED
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  caregiver Caregiver @relation(fields: [caregiverId], references: [id])

  @@index([caregiverId, versionNumber])
}

model CaregiverDocumentVersion {
  id            String   @id @default(uuid())
  caregiverId   String
  versionNumber Int
  documents     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  caregiver Caregiver @relation(fields: [caregiverId], references: [id])
}

model Booking {
  id String @id @default(uuid())

  caretakerId String
  caregiverId String
  elderId     String

  // =============================
  // TIME (CORE LOGIC)
  // =============================
  startDateTime DateTime
  endDateTime   DateTime

  status BookingStatus @default(PENDING)

  notes String?

  // =============================
  // CARE DETAILS
  // =============================
  requiresFullTimeCare  Boolean @default(false)
  requiresNightCare     Boolean @default(false)
  requiresPhysiotherapy Boolean @default(false)
  requiresSpecialDiet   Boolean @default(false)

  // =============================
  // LOCATION
  // =============================
  addressLine1 String
  addressLine2 String?
  city         String
  district     District

  // =============================
  // TRACKING
  // =============================
  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  cancellationReason String?

  // =============================
  // SYSTEM
  // =============================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caretaker Caretaker @relation(fields: [caretakerId], references: [id])
  caregiver Caregiver @relation(fields: [caregiverId], references: [id])
  elder     Elder     @relation(fields: [elderId], references: [id])
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
